# CodeWorld Observatory local environment template
#
# Copy this file to .env.local for local development only.
# .env.local is ignored by git and must never be committed.
#
# DATABASE_URL is server-only. Never expose it through any public-prefixed variable
# or any client-visible configuration, logs, docs, README text, or UI output.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
